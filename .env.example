# Environment configuration for NSM Stack
# Copy this file to .env and fill in values before starting the stack.
# The .env file is ignored by git (see .gitignore).

# ── Elasticsearch ──────────────────────────────────────────────────────────────
# Memory limits for the JVM heap (should be ~50% of available RAM, max 30g)
ES_JAVA_OPTS=-Xms1g -Xmx1g

# ── Logstash ────────────────────────────────────────────────────────────────────
LS_JAVA_OPTS=-Xms512m -Xmx512m

# ── Traffic Generator ────────────────────────────────────────────────────────────
# IP of the target host on nsm-net to probe for port scanning etc.
TARGET_HOST=172.28.0.1
# Seconds between each attack simulation cycle
SCAN_INTERVAL=60

# ── Kibana ───────────────────────────────────────────────────────────────────────
# Kibana URL used by the import_dashboards.sh script
KIBANA_URL=http://localhost:5601
